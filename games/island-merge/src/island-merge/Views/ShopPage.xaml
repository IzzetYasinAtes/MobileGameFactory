<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IslandMerge.ViewModels"
             xmlns:svc="clr-namespace:IslandMerge.Services"
             x:Class="IslandMerge.Views.ShopPage"
             x:DataType="vm:ShopViewModel"
             Title="{Binding Title}"
             BackgroundColor="#0E3B39">
    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Padding="12" RowSpacing="8">
        <Label Grid.Row="0" Text="Magaza" FontSize="24" FontAttributes="Bold" TextColor="White" />

        <Border Grid.Row="1"
                StrokeShape="RoundRectangle 14"
                BackgroundColor="#14524C"
                Stroke="#1F7A6C"
                Padding="10">
            <HorizontalStackLayout Spacing="12">
                <Image Source="{Binding SelectedCharacterImage}" HeightRequest="60" WidthRequest="60" Aspect="AspectFit" />
                <Label Text="Senin ekibin" TextColor="White" VerticalOptions="Center" FontSize="14" />
            </HorizontalStackLayout>
        </Border>

        <CollectionView Grid.Row="2" ItemsSource="{Binding Products}" Margin="0,8">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="svc:IapProduct">
                    <Border Margin="0,6"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="#14524C"
                            Stroke="#1F7A6C"
                            Padding="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" TextColor="White" />
                                <Label Text="{Binding Description}" FontSize="12" TextColor="#C6E0C0" />
                                <Label Text="{Binding PriceDisplay}" FontSize="12" TextColor="#F5A623" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Text="Satin Al"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShopViewModel}}, Path=PurchaseCommand}"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="#F5A623"
                                    TextColor="#1B1B1B" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="3"
                Text="Satin almalari geri yukle"
                Command="{Binding RestoreCommand}"
                BackgroundColor="#1F7A6C"
                TextColor="White" />

        <Label Grid.Row="4" Text="{Binding StatusText}" TextColor="#F5E6A3" />
    </Grid>
</ContentPage>
