<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IslandMerge.ViewModels"
             xmlns:ctrl="clr-namespace:IslandMerge.Controls"
             x:Class="IslandMerge.Views.BoardPage"
             x:DataType="vm:BoardViewModel"
             Title="{Binding Title}"
             BackgroundColor="#0E3B39">
    <Grid Padding="12" RowDefinitions="Auto,*,Auto" RowSpacing="8">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <VerticalStackLayout Grid.Column="0" Spacing="4">
                <Label Text="{Binding QuestText}" TextColor="#F5E6A3" FontSize="14" />
                <HorizontalStackLayout Spacing="16">
                    <Label Text="{Binding Energy, StringFormat='Enerji: {0}'}" TextColor="White" FontSize="12" />
                    <Label Text="{Binding RevealedCount, StringFormat='Acilan: {0}/100'}" TextColor="#C6E0C0" FontSize="12" />
                </HorizontalStackLayout>
                <Label Text="{Binding StatusText}" TextColor="#F5A623" FontSize="12" />
            </VerticalStackLayout>
            <Image Grid.Column="1"
                   x:Name="PetIcon"
                   Source="{Binding PetIconSource}"
                   HeightRequest="48"
                   WidthRequest="48"
                   Aspect="AspectFit"
                   VerticalOptions="Start" />
        </Grid>

        <ctrl:BoardCanvas Grid.Row="1"
                          x:Name="BoardCanvasView"
                          Cells="{Binding Cells}"
                          MergeCommand="{Binding TryMergeCommand}"
                          HorizontalOptions="Fill"
                          VerticalOptions="Fill" />

        <Button Grid.Row="2"
                Text="Reklam izle +50 Enerji"
                Command="{Binding WatchAdForEnergyCommand}"
                IsVisible="{Binding IsEnergyAdVisible}"
                IsEnabled="{Binding CanWatchAdForEnergy}"
                BackgroundColor="#F5A623"
                TextColor="#1B1B1B" />
    </Grid>
</ContentPage>
